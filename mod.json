{
  "geode": "4.0.0",
  "id": "user.macroclickindicator",
  "name": "Macro Click Indicator",
  "version": "1.0.0",
  "developer": "Me",
  "description": "Draw visual click bars from macro JSON over Geometry Dash levels.",
  "gd": { "version": "2.2074", "android": true },
  "platforms": ["android64"],
  "tags": ["visualizer", "gameplay"],
  "links": { "source": "https://github.com/user/macroclickindicator" },
  "settings": {
    "indicator-opacity": {
      "name": "Indicator Opacity",
      "type": "float",
      "default": 0.75,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true }
    },
    "bar-width": {
      "name": "Bar Width",
      "type": "float",
      "default": 7.0,
      "min": 2.0,
      "max": 20.0,
      "control": { "slider": true }
    }
  }
}
